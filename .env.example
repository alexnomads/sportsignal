# SportSignal — Environment Variables Template
# Copy this to .env and fill in your values

# ── Limitless Exchange ────────────────────────────────────────────────────────
# Get from: https://limitless.exchange/api
LIMITLESS_API_KEY=your_api_key_here
LIMITLESS_API_SECRET=your_api_secret_here

# ── API-Football ────────────────────────────────────────────────────────────
# Free tier: 100 calls/day | Sign up at https://v3.football.api-sports.io
API_FOOTBALL_KEY=your_api_football_key_here

# ── Twitter (Optional) ───────────────────────────────────────────────────────
# Install bird CLI: brew install bird (macOS) or build from source
# Get AUTH_TOKEN + CT0 from twitter.com cookies
# Save as .twitter_cookies.env in project root:
# AUTH_TOKEN=your_auth_token
# CT0=your_ct0_token
